packages:
  okf-core
  okf-cli

source-repository-package
  type: git
  location: https://github.com/shinzui/baikai
  tag: 759ddc9e7d110c8935a4c863ef472ae20890aa1f
  subdir:
    baikai
    baikai-kit

-- GHC is provided by the Nix devShell from `nix-haskell-flake` (currently
-- pinned to ghc9124). Add a `with-compiler:` line here if you want
-- cabal to fail loudly when the version drifts from the flake.

test-show-details: direct
tests: True

-- Parallel module compilation
jobs: $ncpus
